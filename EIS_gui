    # ---------- Export helpers ----------
    def export(self, log, default_name):
        if not log:
            return
        p = filedialog.asksaveasfilename(defaultextension=".csv", initialfile=default_name)
        if not p:
            return
        df = pd.DataFrame(log)
        df.to_csv(p, index=False)

    def export_excel(self, log, default_name):
        if not log:
            return
        p = filedialog.asksaveasfilename(defaultextension=".xlsx", initialfile=default_name)
        if not p:
            return
        df = pd.DataFrame(log)
        df.to_excel(p, index=False)

    # ---------- Auto EIS ----------
    def auto_dialog(self):
        win = tk.Toplevel(self.root)
        win.title("Auto EIS")

        ttk.Label(win, text="Duration (min)").grid(row=0, column=0)
        dur = ttk.Entry(win)
        dur.insert(0, "2")
        dur.grid(row=0, column=1)

        ttk.Label(win, text="Wait runeis (s)").grid(row=1, column=0)
        w1 = ttk.Entry(win)
        w1.insert(0, "6")
        w1.grid(row=1, column=1)

        ttk.Label(win, text="Wait readeis (s)").grid(row=2, column=0)
        w2 = ttk.Entry(win)
        w2.insert(0, "2")
        w2.grid(row=2, column=1)

        def start():
            try:
                minutes = float(dur.get())
                w_run  = float(w1.get())
                w_read = float(w2.get())
            except ValueError:
                self.write(self.term, "[AUTO EIS ERROR] Invalid numeric input\n")
                return

            self.stop_auto_eis.clear()
            threading.Thread(
                target=self.auto_loop,
                args=(minutes, w_run, w_read),
                daemon=True
            ).start()
            win.destroy()

        ttk.Button(win, text="Start", command=start).grid(row=3, column=0, columnspan=2)

    def auto_loop(self, minutes, w1, w2):
        end = time.time() + minutes * 60
        self.write(self.term, "[AUTO START]\n")
        while time.time() < end and not self.stop_evt.is_set() and not self.stop_auto_eis.is_set():
            self.send("runeis")
            time.sleep(w1)
            self.send("readeis")
            time.sleep(w2)
        self.write(self.term, "[AUTO END]\n")

