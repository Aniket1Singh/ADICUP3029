    def auto_both_loop(self, total_min, ocv_min, eis_min,
                       ocv_bias, eis_bias, buffer_sec,
                       ocv_period, w_run, w_read,
                       w_eis_run, w_eis_read, first_phase,
                       ocv_bias_enabled, eis_bias_enabled):
        end = time.time() + total_min * 60.0
        self.write(
            self.term,
            f"[AUTO BOTH START] total={total_min:.1f} min, "
            f"OCV={ocv_min:.1f}min@{ocv_bias}mV({'on' if ocv_bias_enabled else 'off'}), "
            f"EIS={eis_min:.1f}min@{eis_bias}mV({'on' if eis_bias_enabled else 'off'}), "
            f"buffer={buffer_sec:.1f}s, OCV_period={ocv_period:.3f}s, first={first_phase}\n"
        )

        ocv_cycle_sec = ocv_min * 60.0
        eis_cycle_sec = eis_min * 60.0

        def should_stop():
            return (time.time() >= end or self.stop_evt.is_set()
                    or self.stop_auto_ocv.is_set() or self.stop_auto_eis.is_set())

        sequence = ["EIS", "OCV"] if first_phase == "EIS" else ["OCV", "EIS"]

        while not should_stop():
            for phase in sequence:
                if should_stop():
                    self.write(self.term, "[AUTO BOTH END - early termination]\n")
                    return

                if phase == "OCV":
                    phase_end = min(time.time() + ocv_cycle_sec, end)

                    if ocv_bias_enabled:
                        self.send(f"setvbias {ocv_bias}")
                        time.sleep(1.0)

                    self.write(
                        self.term,
                        "[AUTO BOTH] OCV phase start "
                        f"(VBias={'{}mV'.format(ocv_bias) if ocv_bias_enabled else 'unchanged'})\n"
                    )

                    while time.time() < phase_end and not should_stop():
                        cycle_start = time.time()
                        self.send("runocv")
                        time.sleep(max(w_run, 0.0))
                        self.send("readocv")
                        time.sleep(max(w_read, 0.0))

                        elapsed = time.time() - cycle_start
                        remain  = ocv_period - elapsed
                        if remain > 0:
                            time.sleep(remain)

                elif phase == "EIS":
                    phase_end = min(time.time() + eis_cycle_sec, end)

                    if eis_bias_enabled:
                        self.send(f"setvbias {eis_bias}")
                        time.sleep(1.0)

                    self.write(
                        self.term,
                        "[AUTO BOTH] EIS phase start "
                        f"(VBias={'{}mV'.format(eis_bias) if eis_bias_enabled else 'unchanged'})\n"
                    )

                    while time.time() < phase_end and not should_stop():
                        self.send("runeis")
                        time.sleep(max(w_eis_run, 0.0))
                        self.send("readeis")
                        time.sleep(max(w_eis_read, 0.0))

                if should_stop():
                    self.write(self.term, "[AUTO BOTH END - early termination]\n")
                    return

                self.write(self.term, f"[AUTO BOTH] Buffer time: {buffer_sec:.1f}s\n")
                t0 = time.time()
                while time.time() - t0 < buffer_sec and not should_stop():
                    time.sleep(0.1)

        self.write(self.term, "[AUTO BOTH END]\n")

    # ---------- stop all auto ----------
    def stop_all_auto(self):
        self.stop_auto_eis.set()
        self.stop_auto_ocv.set()
        self.write(self.term, "[AUTO STOP REQUESTED]\n")

    # ---------- UI Loop ----------
    def _ui_loop(self):
        try:
            while True:
                txt = self.rx_q.get_nowait()
                self.process(txt)
        except Empty:
            pass

        self.update_ocv_plot()
        self.update_cap_plot()
        self.root.after(100, self._ui_loop)

    def write(self, widget, text):
        widget.insert(tk.END, text)
        widget.see(tk.END)

    def process(self, txt):
        t = now()

        # terminal
        self.write(self.term, txt)
        self.term_log.append({"time": t, "raw": txt})
        if self.term_file:
            self.term_file.write(f"{t},{txt}")
            self.term_file.flush()

        # ----------------------------------------------------------------
        # EIS parsing – filter around target_freq
        # Phase from hardware is in DEGREES.
        # Both capacitance_nf() and capacitance_nf_rad() correctly convert
        # degrees → radians using math.radians() before calling math.sin().
        # ----------------------------------------------------------------
        for line in txt.splitlines():
            row = parse_eis(line)
            if not row:
                continue
            f, z, ph = row  # ph is in degrees

            if abs(f - self.target_freq) <= 1.0:
                self.write(self.f1k, line + "\n")
                self.k1_log.append({"time": t, "freq": f, "Z": z, "phase": ph})
                if self.k1_file:
                    self.k1_file.write(f"{t},{f},{z},{ph}\n")
                    self.k1_file.flush()

                # --- Primary capacitance (degrees → radians conversion via math.radians) ---
                c = capacitance_nf(f, z, ph)

                # --- Secondary capacitance (same physics, explicit radians variable shown) ---
                c_rad = capacitance_nf_rad(f, z, ph)

                t_sec_global = time.time() - self.global_start_time

                # Capacitance tab
                self.write(self.cap, f"{t} | {f:.1f} Hz | {c:.6f} nF\n")
                self.cap_log.append({"time": t, "t_sec": t_sec_global, "cap": c})
                if self.cap_file:
                    self.cap_file.write(f"{t},{t_sec_global},{c}\n")
                    self.cap_file.flush()

                # Capacitance (rad path) tab
                self.write(self.cap_rad,
                            f"{t} | {f:.1f} Hz | {c_rad:.6f} nF  "
                            f"[ph_rad={math.radians(ph):.5f}]\n")
                self.cap_rad_log.append({"time": t, "t_sec": t_sec_global, "cap_rad": c_rad})
                if self.cap_rad_file:
                    self.cap_rad_file.write(f"{t},{t_sec_global},{c_rad}\n")
                    self.cap_rad_file.flush()

                if self.cap_data_start_time is None:
                    self.cap_data_start_time = t_sec_global

        # OCV capture
        for line in txt.splitlines():
            if "OCV" in line or "ocv" in line:
                parts = line.replace(",", " ").split()
                val = None
                for tok in reversed(parts):
                    v = safe_float(tok)
                    if v is not None:
                        val = v
                        break
                if val is not None:
                    t_sec_global = time.time() - self.global_start_time
                    self.write(self.ocv_box, f"{t} | {val} mV\n")
                    self.ocv_log.append({"time": t, "t_sec": t_sec_global, "ocv": val})
                    if self.ocv_file:
                        self.ocv_file.write(f"{t},{t_sec_global},{val}\n")
                        self.ocv_file.flush()
                    if self.ocv_data_start_time is None:
                        self.ocv_data_start_time = t_sec_global

    # ---------- OCV plot update / reset ----------
    def update_ocv_plot(self):
        if not self.ocv_ax or not self.ocv_line:
            return
        if not self.ocv_log:
            return

        xs_global = [row["t_sec"] for row in self.ocv_log]
        ys        = [row["ocv"]   for row in self.ocv_log]
        if not xs_global:
            return

        if self.ocv_time_mode.get() == "data" and self.ocv_data_start_time is not None:
            xs = [x - self.ocv_data_start_time for x in xs_global]
        else:
            xs = xs_global

        if self.ocv_plot_style.get() == "Scatter":
            self.ocv_line.set_linestyle("")
            self.ocv_line.set_marker("o")
        else:
            self.ocv_line.set_linestyle("-")
            self.ocv_line.set_marker("o")

        self.ocv_line.set_data(xs, ys)
        self.ocv_ax.relim()
        self.ocv_ax.autoscale_view()
        self.ocv_canvas.draw_idle()

    def reset_ocv_plot(self):
        self.ocv_log.clear()
        self.ocv_data_start_time = None
        if self.ocv_line and self.ocv_ax:
            self.ocv_line.set_data([], [])
            self.ocv_ax.relim()
            self.ocv_ax.autoscale_view()
            self.ocv_canvas.draw_idle()

