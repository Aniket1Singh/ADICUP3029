def list_ports():
    return [p.device for p in serial.tools.list_ports.comports()]


def now():
    return datetime.now().strftime("%H:%M:%S")


def safe_float(s):
    try:
        return float(s.strip())
    except Exception:
        return None


def parse_eis(line):
    parts = line.split(",")
    if len(parts) < 3:
        return None
    f = safe_float(parts[0])
    z = safe_float(parts[1])
    ph = safe_float(parts[2])
    if f is None or z is None or ph is None:
        return None
    return f, z, ph


def capacitance_nf(f, z, ph):
    """
    Compute capacitance in nanofarads from EIS data.
    Phase ph is expected in DEGREES (as received from hardware).
    Converts to radians internally before computing the imaginary
    part of impedance: X = Z * sin(phase_rad).
    C = 1 / (omega * |X|)  [in Farads], converted to nF (* 1e9).
    """
    w = 2 * math.pi * f
    ph_rad = math.radians(ph)          # degrees → radians (correct)
    X = z * math.sin(ph_rad)
    if abs(X) < 1e-12:
        return float("nan")
    return (1 / (w * abs(X))) * 1e9


def capacitance_nf_rad(f, z, ph):
    """
    Compute capacitance in nanofarads from EIS data.
    Phase ph is expected in DEGREES (as received from hardware).
    This function explicitly shows the radians conversion step
    for transparency — it produces the same result as capacitance_nf().
    The 'Capacitance (rad)' tab uses this to confirm consistency
    between both calculation paths.
    C = 1 / (omega * |Z * sin(ph_rad)|)  [nF]
    """
    w = 2 * math.pi * f
    ph_rad = math.radians(ph)          # degrees → radians (correct)
    X = z * math.sin(ph_rad)
    if abs(X) < 1e-12:
        return float("nan")
    return (1 / (w * abs(X))) * 1e9


