    # ---------- Serial ----------
    def connect(self):
        self.ser = serial.Serial(self.port.get(), 115200, timeout=0.2)
        self.stop_evt.clear()
        threading.Thread(target=self.reader, daemon=True).start()
        self.write(self.term, "CONNECTED\n")

    def disconnect(self):
        self.stop_evt.set()
        if self.ser:
            self.ser.close()
        self.ser = None
        self.write(self.term, "DISCONNECTED\n")

    def reader(self):
        while not self.stop_evt.is_set():
            data = self.ser.read(1024)
            if data:
                self.rx_q.put(data.decode(errors="ignore"))

    # ---------- Send / VBias / Target freq ----------
    def send(self, cmd, entry=None):
        if not self.ser or not cmd:
            return
        self.ser.write((cmd + "\r").encode())
        self.write(self.term, f"[TX] {cmd}\n")
        if entry:
            entry.delete(0, tk.END)

    def apply_manual_vbias(self):
        try:
            v = int(float(self.vbias.get()))
        except ValueError:
            self.write(self.term, "[VBias ERROR] Enter integer mV (e.g. 10)\n")
            return
        self.send(f"setvbias {v}")

    def apply_target_freq(self):
        try:
            f = float(self.target_freq_var.get())
            if f <= 0:
                raise ValueError
        except ValueError:
            self.write(self.term, "[TARGET FREQ ERROR] Enter positive frequency in Hz\n")
            return
        self.target_freq = f
        self.write(self.term, f"[TARGET FREQ SET] {self.target_freq:.3f} Hz\n")

