    def auto_ocv_loop(self, minutes, period_sec, w_run, w_read):
        end = time.time() + minutes * 60.0
        self.write(
            self.term,
            f"[AUTO OCV START] duration={minutes:.2f} min, period={period_sec:.3f} s, "
            f"wait_run={w_run:.3f} s, wait_read={w_read:.3f} s\n"
        )

        while time.time() < end and not self.stop_evt.is_set() and not self.stop_auto_ocv.is_set():
            cycle_start = time.time()

            self.send("runocv")
            time.sleep(max(w_run, 0.0))

            self.send("readocv")
            time.sleep(max(w_read, 0.0))

            elapsed = time.time() - cycle_start
            remain  = period_sec - elapsed
            if remain > 0:
                time.sleep(remain)

        self.write(self.term, "[AUTO OCV END]\n")

